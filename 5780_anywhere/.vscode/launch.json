{
    "version": "0.2.0",
    "configurations": [
        { // Lab 3
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/build/lab3/lab3.elf",
            "name": "Debug Lab3 (with OpenOCD)",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "configFiles": [
                "/opt/homebrew/share/openocd/scripts/interface/stlink.cfg",
                "/opt/homebrew/share/openocd/scripts/target/stm32f0x.cfg"
            ],
            // "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "svdPath": "${workspaceRoot}/STM32F0x2.svd"
        },
        { // Lab 5
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/build/lab5/lab5.elf",
            "name": "Debug Lab5 (with OpenOCD)",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "configFiles": [
            "/opt/homebrew/share/openocd/scripts/interface/stlink.cfg",
            "/opt/homebrew/share/openocd/scripts/target/stm32f0x.cfg"
            ],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none"
        },
        {
            "name": "Lab 7 bare debug",
            "cwd": "${workspaceFolder}",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "executable": "${workspaceFolder}/build/Debug/lab7/lab7.elf",
            "configFiles": [
                "/opt/homebrew/share/openocd/scripts/interface/stlink.cfg",
                "/opt/homebrew/share/openocd/scripts/target/stm32f0x.cfg"
            ],
            "showDevDebugOutput": "raw",
            "svdPath": "${workspaceFolder}/STM32F0x2.svd"
        },
        {
            "type": "stlinkgdbtarget",
            "request": "launch",
            "name": "STM32Cube: STM32 Launch ST-Link GDB Server",
            "origin": "snippet",
            "cwd": "${workspaceFolder}",
            "preBuild": "${command:st-stm32-ide-debug-launch.build}",
            "runEntry": "main",
            "imagesAndSymbols": [
                {
                    "imageFileName": "${command:cmake.launchTargetPath}"
                }
            ]
        },
        {
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/build/Debug/lab7/lab7.elf", //"${command:cmake.launchTargetPath}",
            "name": "Lab 7 (RTT graphing)",
            "request": "launch",
            "type": "cortex-debug",
            "openOCDLaunchCommands": [],
            "servertype": "openocd",
            "configFiles": [
                "board/stm32f0discovery.cfg"
            ],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "svdPath": "${workspaceRoot}/STM32F0x2.svd",
            "rttConfig": {
                "enabled": true,
                "address": "auto",
                "decoders": [
                    {
                        "label": "duty_cycle",
                        "port": 0,
                        "type": "graph",
                        "encoding": "unsigned",
                        "graphId": "1",
                        "scale": 1
                    },
                    {
                        "label": "target_rpm",
                        "port": 1,
                        "type": "graph",
                        "encoding": "signed",
                        "graphId": "2",
                        "scale": 1
                    },
                    {
                        "label": "motor_speed",
                        "port": 2,
                        "type": "graph",
                        "encoding": "signed",
                        "graphId": "3",
                        "scale": 1
                    }
                ]
            },
            "graphConfig": [
                {
                    "label": "Graph 1",
                    "timespan": 1,
                    "type": "realtime",
                    "annotate": false,
                    "maximum": 120,
                    "minimum": 0,
                    "plots": [
                        {
                            "graphId": "1",
                            "label": "duty_cycle",
                            "color": "#53753c"
                        },
                        {
                            "graphId": "2",
                            "label": "target_rpm",
                            "color": "#955f20"
                        },
                        {
                            "graphId": "3",
                            "label": "motor_speed",
                            "color": "#B57EDC"
                        }
                    ]
                }
            ]
        }
    ]
}
